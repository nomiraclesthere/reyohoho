{
  "name": "reyohoho",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "seo:fetch": "node scripts/fetch-seo-data.js",
    "seo:assets": "node scripts/generate-seo-assets.js",
    "seo:prepare": "node scripts/fetch-seo-data.js && node scripts/generate-seo-assets.js",
    "postbuild:gh-pages": "node scripts/postbuild-gh-pages.js",
    "build": "node scripts/fetch-seo-data.js && node scripts/generate-seo-assets.js && vite-ssg build && node scripts/postbuild-gh-pages.js",
    "build:github": "cross-env VITE_BASE_URL=/reyohoho/ node scripts/fetch-seo-data.js && cross-env VITE_BASE_URL=/reyohoho/ node scripts/generate-seo-assets.js && cross-env VITE_BASE_URL=/reyohoho/ vite-ssg build --mode github && cross-env VITE_BASE_URL=/reyohoho/ node scripts/postbuild-gh-pages.js",
    "preview": "vite preview",
    "test:unit": "vitest",
    "lint": "eslint --ext .js,.vue src",
    "lint:fix": "eslint --ext .js,.vue src --fix",
    "format": "prettier --write src/",
    "icons": "node scripts/generate-icons.js",
    "build:icons": "node scripts/generate-icons.js && node scripts/fetch-seo-data.js && node scripts/generate-seo-assets.js && vite-ssg build && node scripts/postbuild-gh-pages.js"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@unhead/vue": "^2.1.12",
    "axios": "^1.13.6",
    "dompurify": "^3.3.3",
    "firebase": "^12.10.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "qrcode.vue": "^3.8.0",
    "vite-plugin-pwa": "^1.2.0",
    "vue": "3.5.30",
    "vue-lazyload": "^3.0.0",
    "vue-router": "^5.0.3",
    "vue3-cookies": "^1.0.6",
    "workbox-build": "^7.4.0",
    "workbox-window": "^7.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@pinia/testing": "^1.0.3",
    "@vitejs/plugin-vue": "6.0.5",
    "@vue/test-utils": "2.4.6",
    "cross-env": "^10.1.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "jsdom": "^29.0.0",
    "prettier": "^3.8.1",
    "sass-embedded": "^1.98.0",
    "sharp": "^0.34.5",
    "vite": "8.0.0",
    "vite-plugin-eslint": "^1.8.1",
    "vite-ssg": "^28.3.0",
    "vitest": "^4.1.0",
    "vue-eslint-parser": "^10.4.0"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
